<?php
/**
 * MediLens Secrets Template
 * 
 * TO USE:
 * 1. Copy this file to 'secrets.php' via FTP in your 'api/' folder.
 * 2. Replace the placeholders with your actual keys.
 * 3. Never commit 'secrets.php' to your repository.
 */

// Gemini API Key from Google AI Studio
putenv("GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE");

// Groq API Key (Backup provider)
putenv("GROQ_API_KEY=YOUR_GROQ_KEY_HERE");

// Shared Secret (Must match VITE_AI_PROXY_TOKEN in your GitHub Secrets)
putenv("MEDILENS_PROXY_TOKEN=YOUR_SHARED_SECRET_HERE");
