rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read for all drug intelligence data
    match /drugs/{inn} {
      allow read: if true;
      allow write: if false;

      match /approvals/{country} {
        allow read: if true;
        allow write: if false;
      }
      match /prices/{country} {
        allow read: if true;
        allow write: if false;
      }
      match /ai_cache/{cacheId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /country_dashboards/{country} {
      allow read: if true;
      allow write: if false;
    }

    match /new_drugs_feed/{drugId} {
      allow read: if true;
      allow write: if false;
    }

    match /shortage_forecasts/{forecastId} {
      allow read: if true;
      allow write: if false;
    }

    match /equivalence_cache/{cacheId} {
      allow read: if true;
      allow write: if false;
    }

    // Crowdsourced prices — public read of validated; write if authenticated
    match /crowdsourced_prices/{priceId} {
      allow read: if resource.data.validated == true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['inn', 'country', 'price_local', 'currency'])
                    && request.resource.data.price_local > 0;
    }

    // Crowdsourced drug requests — public write only, strict validation schemas, no public read/update/delete
    match /drug_requests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['drug_name', 'requester_type', 'target_country', 'urgency', 'notes', 'status', 'timestamp'])
                    && request.resource.data.drug_name is string && request.resource.data.drug_name.size() > 0 && request.resource.data.drug_name.size() <= 100
                    && request.resource.data.requester_type is string && request.resource.data.requester_type.size() <= 50
                    && request.resource.data.target_country is string && request.resource.data.target_country.size() <= 10
                    && request.resource.data.urgency is string && request.resource.data.urgency in ['low', 'medium', 'high']
                    && request.resource.data.notes is string && request.resource.data.notes.size() <= 500
                    && request.resource.data.status == 'PENDING'
                    && request.resource.data.timestamp is string && request.resource.data.timestamp.size() <= 40;
      allow read, update, delete: if false;
    }

    // Everything else: deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}